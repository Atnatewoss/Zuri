# --- Runtime ---
ENV=development
PYTHON_VERSION=3.12.7

# --- Supabase PostgreSQL ---
DATABASE_URL='your-supabase-db-url'

# --- ChromaDB Cloud ---
CHROMA_API_KEY='your-chroma-api-key'
CHROMA_TENANT='your-chroma-tenant'
CHROMA_DATABASE='your-chroma-db'

# --- Gemini AI ---
GEMINI_API_KEY='your-gemini-api-key-here'
GEMINI_CHAT_MODEL='gemini-2.5-flash'
GEMINI_EMBEDDING_MODEL='gemini-embedding-001'

# --- App ---
CORS_ORIGINS='https://zuri-ai-concierge.vercel.app,http://localhost:3000'
TEMP_UPLOAD_DIR='_tmp_uploads'

# --- RAG ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# --- Auth ---
APP_SECRET_KEY='replace-with-a-long-random-secret'
SESSION_TOKEN_TTL_SECONDS=86400

# --- Abuse Controls ---
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_RATE_LIMIT_MAX_REQUESTS=20
CHAT_MAX_MESSAGE_LENGTH=5000
BOOKING_CANCEL_RATE_LIMIT_WINDOW_SECONDS=300
BOOKING_CANCEL_RATE_LIMIT_MAX_REQUESTS=8
BOOKING_CANCEL_CODE_RATE_LIMIT_WINDOW_SECONDS=600
BOOKING_CANCEL_CODE_RATE_LIMIT_MAX_REQUESTS=5
CORS_CACHE_TTL_SECONDS=60

# Cron service
BACKEND_HEALTH_URL='https://<your-backend-service>.onrender.com/health'
